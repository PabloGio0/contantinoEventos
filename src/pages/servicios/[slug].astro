---
// src/pages/servicios/[slug].astro
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";
import CtaButton from "../../components/shared/CtaButton.astro";
import { services } from "../../utils/data.ts";

export async function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

// Generar schema estructurado para SEO
const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  "description": service.longDescription || service.heroDescription,
  "provider": {
    "@type": "LocalBusiness",
    "name": "Nombre de tu empresa",
    "areaServed": "CDMX",
    "priceRange": "$$"
  },
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": service.title,
    "itemListElement": service.features.map((feature, index) => ({
      "@type": "Offer",
      "itemOffered": {
        "@type": "Service",
        "name": feature
      },
      "position": index + 1
    }))
  }
};
---

<Layout 
  title={service.seo.title}
  description={service.seo.description}
  keywords={service.seo.keywords.join(", ")}
>
  <!-- Schema markup -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaService)} />

  <!-- Hero Section -->
  <section class="relative pt-36 pb-20 overflow-hidden bg-gradient-to-b from-black via-zinc-900 to-amber-950">
    <!-- Elementos decorativos -->
    <div class="absolute inset-0 opacity-20">
      <div class="absolute top-0 right-0 w-96 h-96 bg-amber-400/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-0 left-0 w-96 h-96 bg-amber-600/10 rounded-full blur-3xl"></div>
    </div>
    
    <!-- Patrón de grid -->
    <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(251, 191, 36, 0.05) 1px, transparent 0); background-size: 40px 40px;"></div>

    <Container className="relative z-10 max-w-4xl mx-auto text-center">
      <span class="inline-block px-4 py-2 rounded-full bg-amber-400/10 border border-amber-400/20 text-amber-400 text-sm font-medium mb-6 backdrop-blur-sm">
        {service.icon || "✨"} Servicio Profesional
      </span>
      
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold text-white leading-tight">
        {service.title}
      </h1>

      <p class="text-zinc-300 text-lg sm:text-xl mt-6 max-w-3xl mx-auto">
        {service.heroDescription}
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
        <CtaButton />
        <a 
          href="/contacto" 
          class="px-8 py-4 border border-amber-400/30 text-amber-400 font-semibold rounded-full hover:bg-amber-400/10 transition-all duration-300 backdrop-blur-sm"
        >
          Solicitar información
        </a>
      </div>
    </Container>
  </section>

  <!-- Descripción larga (SEO) -->
  {service.longDescription && (
    <section class="py-16 bg-black/50">
      <Container className="max-w-4xl mx-auto">
        <div class="bg-zinc-900/30 backdrop-blur-sm border border-amber-400/10 rounded-3xl p-8 md:p-10">
          <h2 class="text-2xl md:text-3xl font-semibold text-white mb-6">
            Servicio profesional de {service.title.toLowerCase()}
          </h2>
          <p class="text-zinc-300 text-lg leading-relaxed">
            {service.longDescription}
          </p>
        </div>
      </Container>
    </section>
  )}

  <!-- Características y Beneficios -->
  <section class="py-20 bg-gradient-to-b from-black to-zinc-950">
    <Container>
      <div class="grid lg:grid-cols-2 gap-12">
        <!-- Características -->
        <div class="bg-zinc-900/50 backdrop-blur-sm rounded-3xl p-8 border border-amber-400/20 hover:border-amber-400/40 transition-all duration-300">
          <h2 class="text-3xl font-semibold text-white mb-8 flex items-center gap-3">
            <span class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center text-black text-xl">✓</span>
            ¿Qué incluye?
          </h2>

          <ul class="space-y-4">
            {service.features.map((feature) => (
              <li class="flex items-start gap-3 text-zinc-300 group">
                <span class="text-amber-400 text-xl mt-0.5 group-hover:scale-110 transition-transform">•</span>
                <span class="group-hover:text-white transition-colors">{feature}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Beneficios -->
        <div class="bg-zinc-900/50 backdrop-blur-sm rounded-3xl p-8 border border-amber-400/20 hover:border-amber-400/40 transition-all duration-300">
          <h2 class="text-3xl font-semibold text-white mb-8 flex items-center gap-3">
            <span class="w-10 h-10 rounded-full bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center text-black text-xl">★</span>
            Beneficios exclusivos
          </h2>

          <ul class="space-y-4">
            {service.benefits.map((benefit) => (
              <li class="flex items-start gap-3 text-zinc-300 group">
                <span class="text-amber-400 text-xl group-hover:scale-110 transition-transform">✓</span>
                <span class="group-hover:text-white transition-colors">{benefit}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </Container>
  </section>

  <!-- CTA Final -->
  <section class="py-20 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-amber-400/10 to-amber-600/10"></div>
    <Container className="relative z-10 text-center max-w-3xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-semibold text-white mb-6">
        ¿Listo para transformar tu evento?
      </h2>
      <p class="text-zinc-300 text-lg mb-10">
        Contáctanos hoy y recibe una cotización personalizada sin compromiso
      </p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <CtaButton />
        <a 
          href="/servicios" 
          class="px-8 py-4 border border-amber-400/30 text-amber-400 font-semibold rounded-full hover:bg-amber-400/10 transition-all duration-300"
        >
          Ver todos los servicios
        </a>
      </div>
    </Container>
  </section>
</Layout>