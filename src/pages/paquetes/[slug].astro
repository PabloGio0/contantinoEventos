---
// src/pages/paquetes/[slug].astro
import Layout from "../../layouts/Layout.astro";
import Container from "../../components/shared/Container.astro";
import CtaButton from "../../components/shared/CtaButton.astro";
import { packages } from "../../utils/data.ts";

export async function getStaticPaths() {
  return packages.map((pkg) => ({
    params: { slug: pkg.slug },
    props: { package: pkg },
  }));
}

const { package: pkg } = Astro.props;
---

<Layout 
  title={`${pkg.name} - Constantino Eventos`}
  description={pkg.description}
>
  <main class="flex flex-col overflow-hidden">

    {/* HERO MEJORADO */}
    <section class="relative pt-36 pb-20 overflow-hidden bg-gradient-to-b from-black via-zinc-900 to-amber-950">
      <!-- Elementos decorativos -->
      <div class="absolute inset-0 opacity-20">
        <div class="absolute top-0 right-0 w-96 h-96 bg-amber-400/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-amber-600/10 rounded-full blur-3xl"></div>
      </div>
      
      <Container className="relative z-10 max-w-4xl mx-auto text-center">
        
        
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight">
          {pkg.name}
        </h1>

        <div class="flex flex-col items-center gap-3 mt-8">
          <div class="flex items-baseline gap-2">
            <span class="text-4xl font-bold text-amber-400">{pkg.price}</span>
            {pkg.priceNote && <span class="text-zinc-400 text-sm">{pkg.priceNote}</span>}
          </div>
          
          <div class="flex items-center gap-2 text-zinc-400">
            <svg class="w-5 h-5 text-amber-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
            <span class="text-lg">Para {pkg.capacity}</span>
          </div>
        </div>

        <p class="text-zinc-300 text-lg mt-6 max-w-2xl mx-auto leading-relaxed">
          {pkg.description}
        </p>

        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <CtaButton package={pkg.name} label="Quiero este paquete" />
          <a 
            href="/contacto" 
            class="px-8 py-4 border border-amber-400/30 text-amber-400 font-semibold rounded-full hover:bg-amber-400 hover:text-black transition-all duration-300"
          >
            ¿Dudas? Contáctanos
          </a>
        </div>
      </Container>
    </section>

    {/* INCLUYE - DISEÑO MEJORADO */}
    <section class="py-10 bg-gradient-to-b from-black to-zinc-950">
      <Container className="max-w-5xl mx-auto">
        <div class="text-center mb-12">
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
            Todo lo que <span class="text-amber-400">incluye</span> este paquete
          </h2>
          <p class="text-zinc-400 max-w-2xl mx-auto">
            Equipo profesional y personal capacitado para que tu evento sea perfecto
          </p>
        </div>

        <div class="bg-zinc-900/50 backdrop-blur-sm rounded-3xl p-8 md:p-10 border border-amber-400/20">
          
          <!-- Highlights visuales -->
          <div class="grid sm:grid-cols-2 gap-4 mb-10">
            {pkg.highlights?.map((item) => (
              <div class="flex items-start gap-3 bg-amber-400/5 p-4 rounded-xl border border-amber-400/10">
                <span class="text-amber-400 text-xl flex-shrink-0">✨</span>
                <p class="text-zinc-200">{item}</p>
              </div>
            ))}
          </div>

          <!-- Lista completa de includes -->
          <div class="mb-8">
            <h3 class="text-xl font-semibold text-amber-400 mb-6 flex items-center gap-2">
              <span class="w-1 h-6 bg-amber-400 rounded-full"></span>
              Incluye además:
            </h3>

            <div class="grid sm:grid-cols-2 gap-4">
              {pkg.includes.map((item) => (
                <div class="flex items-start gap-3 text-zinc-300 group hover:text-white transition-colors">
                  <span class="text-amber-400 mt-1 flex-shrink-0">✓</span>
                  <span class="text-sm md:text-base">{item}</span>
                </div>
              ))}
            </div>
          </div>

          {/* Detalle técnico (si existe) */}
          {pkg.technicalDetails && pkg.technicalDetails.length > 0 && (
            <div class="mt-8 pt-8 border-t border-amber-400/10">
              <h3 class="text-lg font-semibold text-zinc-400 mb-4 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Especificaciones técnicas
              </h3>
              <ul class="grid sm:grid-cols-2 gap-2">
                {pkg.technicalDetails.map((item) => (
                  <li class="text-zinc-500 text-sm flex items-center gap-2">
                    <span class="w-1 h-1 bg-amber-400/50 rounded-full"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          )}

        </div>
      </Container>
    </section>

    {/* UPSELLS - DISEÑO MEJORADO */}
    {pkg.upsells && pkg.upsells.length > 0 && (
      <section class="py-10 bg-black relative overflow-hidden">
        <div class="absolute inset-0 opacity-10">
          <div class="absolute top-0 left-1/4 w-64 h-64 bg-amber-400/20 rounded-full blur-3xl"></div>
        </div>
        
        <Container className="max-w-4xl mx-auto relative z-10">
          <div class="text-center mb-10">
            <span class="inline-block px-4 py-2 rounded-full bg-amber-400/10 border border-amber-400/20 text-amber-400 text-sm font-medium mb-4">
              MEJORA TU EXPERIENCIA
            </span>
            <h2 class="text-3xl font-bold text-white">
              Personaliza aún más <span class="text-amber-400">tu evento</span>
            </h2>
          </div>
          
          <div class="bg-zinc-900/50 backdrop-blur-sm rounded-3xl p-8 border border-amber-400/20">
            <div class="space-y-6">
              {pkg.upsells.map((upsell, index) => (
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 p-4 rounded-xl hover:bg-amber-400/5 transition-colors">
                  <div class="flex-1">
                    <div class="flex items-center gap-3 mb-1">
                      <span class="text-amber-400 font-bold text-lg">{index + 1}.</span>
                      <h3 class="text-lg font-semibold text-white">
                        {upsell.name}
                      </h3>
                    </div>
                    {upsell.description && (
                      <p class="text-zinc-400 text-sm ml-7">
                        {upsell.description}
                      </p>
                    )}
                  </div>
                  <div class="sm:text-right ml-7 sm:ml-0">
                    <span class="inline-block px-4 py-2 bg-amber-400/10 rounded-full text-amber-400 font-bold">
                      {upsell.price}
                    </span>
                  </div>
                </div>
              ))}
            </div>
            
            <div class="mt-8 pt-6 border-t border-amber-400/10 text-center">
              <p class="text-zinc-400 text-sm">
                ¿Te interesa alguna mejora? Menciónala al cotizar
              </p>
            </div>
          </div>
        </Container>
      </section>
    )}

    {/* CTA FINAL */}
    <section class="py-10 bg-gradient-to-b from-zinc-950 to-black">
      <Container className="text-center max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
          ¿Listo para <span class="text-amber-400">reservar</span> tu fecha?
        </h2>
        <p class="text-zinc-400 text-lg mb-8">
          Contamos con fechas limitadas cada mes para garantizar la mejor calidad
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
            <CtaButton package={pkg.name} label="Reservar este paquete" />

          <a 
            href="/paquetes" 
            class="px-8 py-4 border border-amber-400/30 text-amber-400 font-semibold rounded-full hover:bg-amber-400/10 transition-all duration-300"
          >
            Ver otros paquetes
          </a>
        </div>
      </Container>
    </section>

  </main>
</Layout>