---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/sections/Hero.astro";
import ServicesPreview from "../components/sections/ServicesPreview.astro";
import PackagesPreview from "../components/sections/PackagesPreview.astro";
import GalleryPreview from "../components/sections/GalleryPreview.astro";
import Divider from "../components/shared/Divider.astro";
---

<Layout
  title="Producción de Eventos en CDMX — Constantino Eventos & Producciones"
  description="DJ profesional, audio e iluminación, mobiliario y meseros para tu evento en CDMX. Más de 10 años de experiencia. ¡Cotiza gratis!"
  keywords="producción de eventos CDMX, renta de sonido CDMX, DJ profesional CDMX, iluminación para eventos, paquetes para eventos"
>
  <main class="flex flex-col overflow-hidden ">
    <!-- Gancho visual + CTA principal -->
    <Hero />

    <ServicesPreview />
    <Divider variant="line" />

    <PackagesPreview />
    <Divider variant="line" />

    <GalleryPreview />
    <Divider variant="wave" flip={true} />

    <!-- CTA final de cierre -->
    <section
      class="py-20 relative overflow-hidden bg-gradient-to-b from-zinc-950 to-black"
    >
      <div
        class="absolute inset-0 bg-gradient-to-br from-amber-400/5 to-transparent pointer-events-none"
      >
      </div>
      <div class="max-w-2xl mx-auto px-6 text-center relative z-10">
        <h2 class="text-3xl md:text-4xl font-semibold text-white mb-4">
          ¿Listo para crear algo <span class="text-amber-400">inolvidable</span
          >?
        </h2>
        <p class="text-zinc-400 text-lg mb-10">
          Cuéntanos sobre tu evento y te damos una cotización sin compromiso.
        </p>
        <div
          class="flex flex-col sm:flex-row items-center justify-center gap-4"
        >
          <a
            href="https://wa.me/525581657250?text=Hola,%20quiero%20cotizar%20un%20evento"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-3 px-8 py-4 rounded-full font-semibold
              bg-gradient-to-r from-amber-400 to-amber-500 text-black
              hover:from-amber-500 hover:to-amber-600
              transition-all duration-300 shadow-lg shadow-amber-400/20 hover:scale-105"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path>
            </svg>
            Cotizar mi evento
          </a>
          <a
            href="/contacto"
            class="px-8 py-4 border border-amber-400/30 text-amber-400 font-semibold rounded-full
              hover:bg-amber-400/10 transition-all duration-300"
          >
            Llenar formulario
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>
