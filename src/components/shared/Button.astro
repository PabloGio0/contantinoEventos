---
export interface Props {
  variant: "primary";
  className?: string;
}

const { variant = "primary", className } = Astro.props;

const variants = {
  primary:
    "border border-white text-white hover:bg-amber-400 hover:text-black hover:border-black transition-all duration-500",
};
---

<button
  class={`px-6 py-3 rounded-full font-medium ${variants[variant]} ${className}`}
>
  <slot />
</button>

