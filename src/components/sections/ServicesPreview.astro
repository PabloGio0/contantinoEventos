---
// src/components/sections/ServicesPreview.astro
import Container from "../shared/Container.astro";
import ServiceCard from "../cards/Service.astro";
import { services } from "../../utils/data.ts";

// Solo los 3 primeros servicios (los más relevantes)
const featured = services.slice(0, 3);
---

<section class="relative py-20 overflow-hidden bg-gradient-to-b from-black to-zinc-950">
  <span class="w-96 h-96 rounded-full bg-amber-400/5 blur-3xl absolute -left-20 top-0 pointer-events-none"></span>

  <Container className="relative z-10">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12">
      <div>
        <span class="inline-block px-4 py-2 rounded-full bg-amber-400/10 border border-amber-400/20 text-amber-400 text-sm font-medium mb-4">
          Nuestros Servicios
        </span>
        <h2 class="text-3xl md:text-4xl font-semibold text-white">
          Todo lo que necesitas <span class="text-amber-400">en un solo equipo</span>
        </h2>
      </div>
      <a
        href="/servicios"
        class="flex-shrink-0 text-amber-400 hover:text-amber-300 transition-colors text-sm font-medium flex items-center gap-2 group"
      >
        Ver todos los servicios
        <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
      </a>
    </div>

    <!-- Grid 3 servicios -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {featured.map((service) => (
        <a href={`/servicios/${service.slug}`} class="group block h-full">
          <ServiceCard
            title={service.title}
            features={service.features.slice(0, 3)}
            icon={service.icon || "✨"}
          />
        </a>
      ))}
    </div>
  </Container>
</section>