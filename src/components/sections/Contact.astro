---
// src/components/sections/Contact.astro
import Container from "../shared/Container.astro";

export interface Props {
  className?: string;
}
const { className = "" } = Astro.props;

const PHONE = "525581657250";
---

<section
  id="contacto"
  class={`relative py-20 overflow-hidden bg-gradient-to-b from-zinc-950 to-black ${className}`}
>
  <!-- Decorativos -->
  <span class="w-72 h-72 rounded-full bg-amber-400/10 blur-3xl absolute -left-20 top-1/4 pointer-events-none"></span>
  <span class="w-96 h-96 rounded-full bg-amber-600/5 blur-3xl absolute -right-20 bottom-0 pointer-events-none"></span>
  <span class="w-80 h-80 rounded-full bg-amber-400/5 blur-3xl absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 pointer-events-none"></span>
  <span class="w-60 h-60 rounded-full bg-amber-500/10 blur-3xl absolute -right-10 top-1/3 pointer-events-none"></span>
  <span class="w-40 h-40 rounded-full bg-amber-400/20 blur-3xl absolute -left-10 bottom-1/4 pointer-events-none"></span>

  <Container className="relative z-10">
    <div class="max-w-3xl mx-auto">

      <!-- Header -->
      <div class="text-center mb-12">
        <span class="inline-block px-4 py-2 rounded-full bg-amber-400/10 border border-amber-400/20 text-amber-400 text-sm font-medium mb-4 mt-6">
          COTIZA TU EVENTO
        </span>
        <h2 class="text-3xl sm:text-4xl font-semibold text-white mb-4">
          Cuéntanos sobre <span class="text-amber-400">tu evento</span>
        </h2>
        <p class="text-zinc-400 text-lg">
          Llena el formulario y te contactamos por WhatsApp con una cotización personalizada.
        </p>
      </div>

      <!-- Formulario -->
      <div class="bg-zinc-900/60 backdrop-blur-sm border border-amber-400/20 rounded-3xl p-8 md:p-10">
        <div id="contact-form" class="space-y-6">

          <!-- Fila: Nombre + Teléfono -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-zinc-300 mb-2">
                Nombre <span class="text-amber-400">*</span>
              </label>
              <input
                id="f-name"
                type="text"
                placeholder="Tu nombre completo"
                class="w-full px-4 py-3 rounded-xl bg-zinc-800/80 border border-zinc-700
                  text-white placeholder-zinc-500
                  focus:outline-none focus:border-amber-400/60 focus:bg-zinc-800
                  transition-all duration-300"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-300 mb-2">
                Teléfono <span class="text-amber-400">*</span>
              </label>
              <input
                id="f-phone"
                type="tel"
                placeholder="55 1234 5678"
                class="w-full px-4 py-3 rounded-xl bg-zinc-800/80 border border-zinc-700
                  text-white placeholder-zinc-500
                  focus:outline-none focus:border-amber-400/60 focus:bg-zinc-800
                  transition-all duration-300"
              />
            </div>
          </div>

          <!-- Tipo de evento -->
          <div>
            <label class="block text-sm font-medium text-zinc-300 mb-2">
              Tipo de evento <span class="text-amber-400">*</span>
            </label>
            <select
              id="f-type"
              class="w-full px-4 py-3 rounded-xl bg-zinc-800/80 border border-zinc-700
                text-white
                focus:outline-none focus:border-amber-400/60 focus:bg-zinc-800
                transition-all duration-300 appearance-none cursor-pointer"
            >
              <option value="" disabled selected class="text-zinc-500">Selecciona el tipo de evento</option>
              <option value="Boda">Boda</option>
              <option value="XV Años">XV Años</option>
              <option value="Cumpleaños">Cumpleaños</option>
              <option value="Evento corporativo">Evento corporativo</option>
              <option value="Graduación">Graduación</option>
              <option value="Conferencia">Conferencia</option>
              <option value="Otro">Otro</option>
            </select>
          </div>

          <!-- Fila: Fecha + Hora -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-zinc-300 mb-2">
                Fecha del evento <span class="text-amber-400">*</span>
              </label>
              <input
                id="f-date"
                type="date"
                class="w-full px-4 py-3 rounded-xl bg-zinc-800/80 border border-zinc-700
                  text-white
                  focus:outline-none focus:border-amber-400/60 focus:bg-zinc-800
                  transition-all duration-300 cursor-pointer
                  [color-scheme:dark]"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-300 mb-2">
                Horario aproximado
              </label>
              <input
                id="f-time"
                type="text"
                placeholder="ej: 6:00 PM – 12:00 AM"
                class="w-full px-4 py-3 rounded-xl bg-zinc-800/80 border border-zinc-700
                  text-white placeholder-zinc-500
                  focus:outline-none focus:border-amber-400/60 focus:bg-zinc-800
                  transition-all duration-300"
              />
            </div>
          </div>

          <!-- Fila: Invitados + Lugar -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-sm font-medium text-zinc-300 mb-2">
                Número de invitados <span class="text-amber-400">*</span>
              </label>
              <select
                id="f-guests"
                class="w-full px-4 py-3 rounded-xl bg-zinc-800/80 border border-zinc-700
                  text-white
                  focus:outline-none focus:border-amber-400/60 focus:bg-zinc-800
                  transition-all duration-300 appearance-none cursor-pointer"
              >
                <option value="" disabled selected>Selecciona un rango</option>
                <option value="Menos de 30 personas">Menos de 30 personas</option>
                <option value="30 – 50 personas">30 – 50 personas</option>
                <option value="50 – 80 personas">50 – 80 personas</option>
                <option value="80 – 120 personas">80 – 120 personas</option>
                <option value="Más de 120 personas">Más de 120 personas</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-zinc-300 mb-2">
                Lugar del evento
              </label>
              <input
                id="f-place"
                type="text"
                placeholder="Colonia, Alcaldía o Salón"
                class="w-full px-4 py-3 rounded-xl bg-zinc-800/80 border border-zinc-700
                  text-white placeholder-zinc-500
                  focus:outline-none focus:border-amber-400/60 focus:bg-zinc-800
                  transition-all duration-300"
              />
            </div>
          </div>

          <!-- Paquete de interés -->
          <div>
            <label class="block text-sm font-medium text-zinc-300 mb-2">
              Paquete o servicio de interés
            </label>
            <select
              id="f-package"
              class="w-full px-4 py-3 rounded-xl bg-zinc-800/80 border border-zinc-700
                text-white
                focus:outline-none focus:border-amber-400/60 focus:bg-zinc-800
                transition-all duration-300 appearance-none cursor-pointer"
            >
              <option value="">No lo sé todavía / Necesito asesoría</option>
              <optgroup label="Paquetes">
                <option value="Paquete Standard ($8,490)">Paquete Standard — $8,490 (30-50 personas)</option>
                <option value="Paquete Plus ($15,900)">Paquete Plus — $15,900 (50-80 personas) ⭐</option>
                <option value="Paquete Premium ($24,900)">Paquete Premium — $24,900 (80-120+ personas)</option>
                <option value="Paquete Conferencias ($18,900)">Paquete Conferencias — $18,900 (hasta 150 personas)</option>
                <option value="Paquete Personalizado">Arma tu paquete a la medida</option>
              </optgroup>
              <optgroup label="Servicios sueltos">
                <option value="Audio e Iluminación">Audio e Iluminación</option>
                <option value="DJ Profesional">DJ Profesional</option>
                <option value="Mobiliario y Montaje">Mobiliario y Montaje</option>
                <option value="Personal y Coordinación">Personal y Coordinación</option>
              </optgroup>
            </select>
          </div>

          <!-- Notas adicionales -->
          <div>
            <label class="block text-sm font-medium text-zinc-300 mb-2">
              ¿Algo más que quieras agregar?
            </label>
            <textarea
              id="f-notes"
              rows="3"
              placeholder="Extras, dudas específicas, temática del evento..."
              class="w-full px-4 py-3 rounded-xl bg-zinc-800/80 border border-zinc-700
                text-white placeholder-zinc-500
                focus:outline-none focus:border-amber-400/60 focus:bg-zinc-800
                transition-all duration-300 resize-none"
            ></textarea>
          </div>

          <!-- Error message -->
          <p id="f-error" class="hidden text-red-400 text-sm text-center">
            Por favor completa los campos obligatorios (nombre, teléfono, tipo de evento, fecha e invitados).
          </p>

          <!-- Botón enviar -->
          <button
            id="f-submit"
            type="button"
            class="w-full py-4 rounded-xl font-semibold text-black
              bg-gradient-to-r from-amber-400 to-amber-500
              hover:from-amber-500 hover:to-amber-600
              transition-all duration-300
              flex items-center justify-center gap-3
              shadow-lg shadow-amber-400/20 hover:shadow-amber-400/30
              hover:scale-[1.01] active:scale-[0.99]"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar por WhatsApp
          </button>

          <p class="text-center text-zinc-500 text-xs">
            Al enviar, se abrirá WhatsApp con tu información lista. Sin spam, sin compromiso.
          </p>

        </div>
      </div>

      <!-- Info rápida debajo del formulario -->
      <div class="grid sm:grid-cols-3 gap-4 mt-8">
        <div class="flex items-center gap-3 bg-zinc-900/40 border border-amber-400/10 rounded-2xl p-4">
          <span class="text-2xl">⚡</span>
          <div>
            <p class="text-white text-sm font-medium">Respuesta rápida</p>
            <p class="text-zinc-500 text-xs">En menos de 2 horas</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-zinc-900/40 border border-amber-400/10 rounded-2xl p-4">
          <span class="text-2xl">📋</span>
          <div>
            <p class="text-white text-sm font-medium">Cotización gratis</p>
            <p class="text-zinc-500 text-xs">Sin compromiso</p>
          </div>
        </div>
        <div class="flex items-center gap-3 bg-zinc-900/40 border border-amber-400/10 rounded-2xl p-4">
          <span class="text-2xl">📅</span>
          <div>
            <p class="text-white text-sm font-medium">Fechas limitadas</p>
            <p class="text-zinc-500 text-xs">Reserva con anticipación</p>
          </div>
        </div>
      </div>

    </div>
  </Container>
</section>

<script define:vars={{ PHONE }}>
  const btn = document.getElementById("f-submit");
  const errMsg = document.getElementById("f-error");

  btn?.addEventListener("click", () => {
    const name    = document.getElementById("f-name")?.value.trim();
    const phone   = document.getElementById("f-phone")?.value.trim();
    const type    = document.getElementById("f-type")?.value;
    const date    = document.getElementById("f-date")?.value;
    const time    = document.getElementById("f-time")?.value.trim();
    const guests  = document.getElementById("f-guests")?.value;
    const place   = document.getElementById("f-place")?.value.trim();
    const pkg     = document.getElementById("f-package")?.value;
    const notes   = document.getElementById("f-notes")?.value.trim();

    // Validación básica
    if (!name || !phone || !type || !date || !guests) {
      errMsg?.classList.remove("hidden");
      errMsg?.scrollIntoView({ behavior: "smooth", block: "center" });
      return;
    }
    errMsg?.classList.add("hidden");

    // Formatear fecha legible
    const [y, m, d] = date.split("-");
    const months = ["enero","febrero","marzo","abril","mayo","junio","julio","agosto","septiembre","octubre","noviembre","diciembre"];
    const readableDate = `${parseInt(d)} de ${months[parseInt(m)-1]} de ${y}`;

    // Construir mensaje
    let msg = `¡Hola! Me interesa cotizar un evento con Constantino Eventos 🎉\n\n`;
    msg += `👤 *Nombre:* ${name}\n`;
    msg += `📱 *Teléfono:* ${phone}\n`;
    msg += `🎊 *Tipo de evento:* ${type}\n`;
    msg += `📅 *Fecha:* ${readableDate}\n`;
    if (time)   msg += `🕐 *Horario:* ${time}\n`;
    msg += `👥 *Invitados:* ${guests}\n`;
    if (place)  msg += `📍 *Lugar:* ${place}\n`;
    if (pkg)    msg += `📦 *Paquete/Servicio:* ${pkg}\n`;
    if (notes)  msg += `📝 *Notas:* ${notes}\n`;
    msg += `\n¿Tienen disponibilidad para esa fecha?`;

    const url = `https://wa.me/${PHONE}?text=${encodeURIComponent(msg)}`;
    window.open(url, "_blank", "noopener,noreferrer");
  });
</script>