---
// src/components/sections/Packages.astro
import Container from "../shared/Container.astro";
import Title from "../shared/Title.astro";
import Paragraph from "../shared/Paragraph.astro";
import PackageCard from "../cards/PackageCard.astro";
import { packages } from "../../utils/data.ts";

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section
  id="paquetes"
  class=`relative py-20 overflow-hidden bg-gradient-to-br from-black via-zinc-900 to-amber-950 ${className}`
>
  <!-- Elementos decorativos -->
  <div class="absolute inset-0 opacity-30">
    <div class="absolute top-0 left-0 w-96 h-96 bg-amber-400/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-amber-600/10 rounded-full blur-3xl"></div>
  </div>

  <!-- Patrón de grid -->
  <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(251, 191, 36, 0.05) 1px, transparent 0); background-size: 40px 40px;"></div>

  <Container className="relative z-10 space-y-16">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mt-6 mb-6">
      <span class="inline-block px-4 py-2 rounded-full bg-amber-400/10 border border-amber-400/20 text-amber-400 text-sm font-medium mb-4">
        PAQUETES
      </span>
      
      <Title className="text-white mb-4">
        Elige el paquete perfecto <span class="text-amber-400">para tu evento</span>
      </Title>
      
      <Paragraph className="text-zinc-400">
        Desde eventos íntimos hasta grandes producciones. Todos nuestros paquetes incluyen 
        equipo profesional y personal capacitado.
      </Paragraph>
    </div>

    <!-- Grid de paquetes -->
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 auto-rows-fr">
      {packages.map((pkg) => (
        <a
          href={`/paquetes/${pkg.slug}`}
          class="group relative block h-full"
        >
          <PackageCard
            name={pkg.name}
            description={pkg.description}
            capacity={pkg.capacity}
            price={pkg.price}
            priceNote={pkg.priceNote}
            icon={pkg.icon}
            includes={pkg.includes}
            upsells={pkg.upsells}
            featured={pkg.featured}
            type={pkg.type}
          />
        </a>
      ))}
    </div>

    <!-- Nota sobre karaoke y extras -->
    <div class="text-center">
      <div class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-zinc-900/50 border border-amber-400/20 text-zinc-400 text-sm">
        <span class="text-amber-400">✨</span>
        Todos los paquetes pueden incluir karaoke (+$500), pista de baile o micrófonos adicionales
      </div>
    </div>
  </Container>
</section>