---
// src/components/sections/PackagesPreview.astro
import Container from "../shared/Container.astro";
import PackageCard from "../cards/PackageCard.astro";
import { packages } from "../../utils/data.ts";

// Mostramos: el destacado (Plus), el Premium y el Personalizado
const preview = packages.filter(p =>
  ["paquete-plus", "paquete-premium", "paquete-personalizado"].includes(p.slug)
);
---

<section class="relative py-20 overflow-hidden bg-gradient-to-b from-zinc-950 to-black">
  <span class="w-96 h-96 rounded-full bg-amber-600/5 blur-3xl absolute -right-20 bottom-0 pointer-events-none"></span>
  <div class="absolute inset-0 pointer-events-none"
    style="background-image: radial-gradient(circle at 1px 1px, rgba(251,191,36,0.03) 1px, transparent 0); background-size: 40px 40px;">
  </div>

  <Container className="relative z-10">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-4 mb-12">
      <div>
        <span class="inline-block px-4 py-2 rounded-full bg-amber-400/10 border border-amber-400/20 text-amber-400 text-sm font-medium mb-4">
          Paquetes
        </span>
        <h2 class="text-3xl md:text-4xl font-semibold text-white">
          Elige el paquete <span class="text-amber-400">que se ajusta a tu evento</span>
        </h2>
      </div>
      <a
        href="/paquetes"
        class="flex-shrink-0 text-amber-400 hover:text-amber-300 transition-colors text-sm font-medium flex items-center gap-2 group"
      >
        Ver todos los paquetes
        <span class="group-hover:translate-x-1 transition-transform duration-300">→</span>
      </a>
    </div>

    <!-- Grid 3 paquetes -->
    <div class="grid md:grid-cols-3 gap-6">
      {preview.map((pkg) => (
        <a href={`/paquetes/${pkg.slug}`} class="group block h-full">
          <PackageCard
            name={pkg.name}
            description={pkg.description}
            capacity={pkg.capacity}
            price={pkg.price}
            priceNote={pkg.priceNote}
            icon={pkg.icon}
            includes={pkg.highlights}
            featured={pkg.featured}
            type={pkg.type}
          />
        </a>
      ))}
    </div>

    <!-- Nota extras -->
    <p class="text-center text-zinc-500 text-sm mt-8">
      ¿No encontraste lo que buscas?
      <a href="/paquetes" class="text-amber-400 hover:underline ml-1">
        Tenemos más opciones →
      </a>
    </p>
  </Container>
</section>