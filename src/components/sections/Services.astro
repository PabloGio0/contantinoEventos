---
import Service from "../cards/Service.astro";
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import Title from "../shared/Title.astro";
import { services } from "../../utils/data.ts";

type ServicesProps = {
  title: string;
  features: string[];
  icon: string;
};

export interface Props {
  className?: string;
}

const { className } = Astro.props;
---

<section
  id="services"
  class=`relative py-20 overflow-hidden bg-gradient-to-br from-black via-zinc-900 to-amber-950 ${className}`
>
  <!-- Elementos decorativos abstractos -->
  <div class="absolute inset-0 opacity-30">
    <div class="absolute top-0 left-0 w-96 h-96 bg-amber-400/10 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-amber-600/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-r from-amber-400/5 to-transparent rounded-full blur-3xl"></div>
  </div>

  <!-- Patrón de grid sutil -->
  <div class="absolute inset-0" style="background-image: radial-gradient(circle at 1px 1px, rgba(251, 191, 36, 0.05) 1px, transparent 0); background-size: 40px 40px;"></div>

  <Container className="relative z-10 space-y-16">
    <!-- Header con diseño mejorado -->
    <div class="text-center max-w-3xl mx-auto mt-16">
      
      <Title className="text-white mb-4">
        Producción técnica que convierte tu evento en 
        <span class="text-amber-400">una experiencia inolvidable</span>
      </Title>
      
      <Paragraph className="text-zinc-400">
        Desde la música hasta la logística completa, te ofrecemos todo lo necesario 
        para que tu evento sea inolvidable.
      </Paragraph>
    </div>

    <div class="bg-zinc-900/70 border border-amber-400/30 rounded-3xl p-10 text-center relative overflow-hidden">

      <span class="text-amber-400 text-sm uppercase tracking-wider">
        Servicio Principal
      </span>

      <h3 class="text-3xl font-semibold text-white mt-4">
        DJ Profesional + Producción Técnica Integral
      </h3>

      <p class="text-zinc-400 mt-4 max-w-2xl mx-auto">
        No solo reproducimos música. Diseñamos la atmósfera completa
        con audio de alta fidelidad, iluminación arquitectónica y
        control técnico profesional.
      </p>

    </div>
    <!-- Grid de servicios con hover effects mejorados -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {
        services.map((service: ServicesProps, index) => {
          return (
            <div class="group relative">
              <!-- Efecto de fondo en hover -->
              <div class="absolute inset-0 bg-gradient-to-r from-amber-400/20 to-amber-600/20 rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              
              <!-- Tarjeta principal -->
              <div class="relative bg-zinc-900/50 backdrop-blur-sm border border-amber-400/30 rounded-2xl p-8 hover:border-amber-400/50 transition-all duration-300 hover:shadow-2xl hover:shadow-amber-400/10">
                <!-- Icono con efecto -->
                <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-amber-400 to-amber-600 flex items-center justify-center mb-6 transform group-hover:scale-110 group-hover:rotate-3 transition-all duration-300">
                  <span class="text-3xl text-black">{service.icon}</span>
                </div>
                
                <!-- Título -->
                <h3 class="text-xl font-semibold text-white mb-4 group-hover:text-amber-400 transition-colors">
                  {service.title}
                </h3>
                
                <!-- Características -->
                <ul class="space-y-3">
                  {service.features.map((feature) => (
                    <li class="flex items-start gap-2 text-zinc-400 group-hover:text-zinc-300 transition-colors">
                      <span class="text-amber-400 mt-1">•</span>
                      <span class="text-sm">{feature}</span>
                    </li>
                  ))}
                </ul>
                
                <!-- Línea decorativa inferior -->
                <div class="absolute bottom-0 left-8 right-8 h-0.5 bg-gradient-to-r from-transparent via-amber-400/50 to-transparent transform scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></div>
              </div>
            </div>
          );
        })
      }
    </div>

    <!-- CTA adicional -->
    <div class="text-center mt-12">
      <a 
        href="/contacto" 
        class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-amber-400 to-amber-500 text-black font-semibold rounded-full hover:from-amber-500 hover:to-amber-600 transition-all duration-300 shadow-lg shadow-amber-400/20 hover:shadow-amber-400/30"
      >
        Agenda tu fecha ahora
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
      <p class="text-zinc-500 text-sm mt-3">
        Fechas limitadas cada mes
      </p>
    </div>
  </Container>
</section>