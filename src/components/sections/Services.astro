---
// src/pages/servicios/index.astro
//import Layout from "../../layouts/Layout.astro";
import ServiceCard from "../cards/Service.astro";
import Container from "../shared/Container.astro";
import Paragraph from "../shared/Paragraph.astro";
import Title from "../shared/Title.astro";
import { services } from "../../utils/data.ts";

export interface Props {
  className?: string;
}

const { className } = Astro.props;

// Schema para la página de listado
const schemaCollection = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "Servicios para Eventos en CDMX",
  description:
    "Producción integral para eventos: audio, iluminación, DJ, mobiliario y personal profesional",
  numberOfItems: services.length,
  itemListElement: services.map((service, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: `https://tusitio.com/servicios/${service.slug}`,
    name: service.title,
  })),
};
---

<script
  type="application/ld+json"
  set:html={JSON.stringify(schemaCollection)}
/>

<section
  id="services"
  class=`relative py-20 overflow-hidden bg-gradient-to-br from-black via-zinc-900 to-amber-950 ${className}`
>
  <!-- Elementos decorativos -->
  <div class="absolute inset-0 opacity-30">
    <div
      class="absolute top-0 left-0 w-96 h-96 bg-amber-400/10 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute bottom-0 right-0 w-96 h-96 bg-amber-600/10 rounded-full blur-3xl"
    >
    </div>
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-gradient-to-r from-amber-400/5 to-transparent rounded-full blur-3xl"
    >
    </div>
  </div>

  <!-- Patrón de grid -->
  <div
    class="absolute inset-0"
    style="background-image: radial-gradient(circle at 1px 1px, rgba(251, 191, 36, 0.05) 1px, transparent 0); background-size: 40px 40px;"
  >
  </div>

  <Container className="relative z-10 space-y-16">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto mt-16">
      <span
        class="inline-block px-4 py-2 rounded-full bg-amber-400/10 border border-amber-400/20 text-amber-400 text-sm font-medium mb-4"
      >
        Nuestros Servicios
      </span>

      <Title className="text-white mb-4">
        Producción técnica que convierte tu evento en
        <span class="text-amber-400"> una experiencia inolvidable</span>
      </Title>

      <Paragraph className="text-zinc-400">
        Desde la música hasta la logística completa, te ofrecemos todo lo
        necesario para que tu evento sea inolvidable.
      </Paragraph>
    </div>

    <!-- Servicio Destacado -->
    <div
      class="bg-zinc-900/70 backdrop-blur-sm border border-amber-400/30 rounded-3xl p-8 md:p-10 text-center relative overflow-hidden group hover:border-amber-400/60 transition-all duration-500"
    >
      <div
        class="absolute inset-0 bg-gradient-to-r from-amber-400/0 via-amber-400/5 to-amber-400/0 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-1000"
      >
      </div>

      <span
        class="text-amber-400 text-sm uppercase tracking-wider font-semibold"
      >
        ✦ Servicio Integral ✦
      </span>

      <h3
        class="text-2xl md:text-3xl lg:text-4xl font-semibold text-white mt-4"
      >
        DJ Profesional + Producción Técnica Integral
      </h3>

      <p class="text-zinc-400 mt-4 max-w-2xl mx-auto text-lg">
        No solo reproducimos música. Diseñamos la atmósfera completa con audio
        de alta fidelidad, iluminación arquitectónica y control técnico
        profesional.
      </p>

      <div class="mt-8">
        <a
          href="/contacto"
          class="inline-flex items-center gap-2 px-6 py-3 bg-amber-400/10 border border-amber-400/30 text-amber-400 rounded-full hover:bg-amber-400/20 transition-all duration-300"
        >
          Solicitar información
          <span class="text-lg">→</span>
        </a>
      </div>
    </div>

    <!-- Grid de servicios -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 auto-rows-fr">
      {
        services.map((service) => (
          <a
            href={`/servicios/${service.slug}`}
            class="group relative block h-full"
          >
            <ServiceCard
              title={service.title}
              features={service.features.slice(0, 3)}
              icon={service.icon || "✨"}
            />
          </a>
        ))
      }
    </div>

    <!-- CTA adicional -->
    <div class="text-center mt-12">
      <a
        href="/contacto"
        class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-amber-400 to-amber-500 text-black font-semibold rounded-full hover:from-amber-500 hover:to-amber-600 transition-all duration-300 shadow-lg shadow-amber-400/20 hover:shadow-amber-400/30"
      >
        Agenda tu fecha ahora
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
      <p class="text-zinc-500 text-sm mt-3">
        Fechas limitadas cada mes • Reserva con anticipación
      </p>
    </div>
  </Container>
</section>
