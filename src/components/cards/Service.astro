---
import Paragraph from "../shared/Paragraph.astro";

export interface Props {
  title: string;
  features: string[];
  icon: string;
}

const { title, features, icon } = Astro.props;
---

<div
  class="h-full p-5 sm:p-6 lg:p-8 relative overflow-hidden rounded-3xl
    bg-zinc-900/50 backdrop-blur-sm
    border border-amber-400/20
    hover:border-amber-400/50
    hover:shadow-2xl hover:shadow-amber-400/10
    transition-all duration-300
    flex flex-col"
>
  <!-- Icono con estilo ámbar -->
  <div
    class="w-14 h-14 rounded-xl bg-gradient-to-br from-amber-400/40 to-amber-600/40 flex items-center justify-center text-2xl text-black flex-shrink-0"
  >
    <span set:html={icon} />
  </div>
  
  <!-- Contenido con flex-grow para ocupar espacio uniforme -->
  <div class="mt-5 flex-grow flex flex-col">
    <!-- Título con altura mínima para 2 líneas -->
    <h2 class="text-lg md:text-xl font-semibold text-white mb-3 min-h-[3.5rem] line-clamp-2">
      {title}
    </h2>
    
    <!-- Características con flex-grow -->
    <div class="space-y-3 flex-grow">
      {
        features.map((feature) => (
          <div class="flex items-start gap-2 text-zinc-300 group-hover:text-zinc-200 transition-colors">
            <span class="text-amber-400 font-bold flex-shrink-0 mt-0.5">✓</span>
            <span class="text-sm leading-relaxed">{feature}</span>
          </div>
        ))
      }
    </div>
    
    <!-- Espaciador para mantener consistencia (opcional) -->
    <div class="mt-4 pt-2 border-t border-amber-400/10 text-xs text-amber-400/60 text-right hover:text-white transition-colors">
      Ver detalles →
    </div>
  </div>

  <!-- Elemento decorativo de fondo (sutil) -->
  <div class="absolute top-0 right-0 w-32 h-32 bg-amber-400/5 rounded-full blur-2xl"></div>
</div>

<style>
  /* Fallback para line-clamp si no está disponible en Tailwind */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>