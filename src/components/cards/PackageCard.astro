---
// src/components/cards/PackageCard.astro
import Paragraph from "../shared/Paragraph.astro";

export interface Props {
  name: string;
  description: string;
  capacity: string;
  price: string;
  priceNote?: string;
  icon: string;
  includes: string[];
  upsells?: Array<{ name: string; price: string; description?: string }>;
  featured?: boolean;
  type: string;
}

const {
  name,
  description,
  capacity,
  price,
  priceNote,
  icon,
  includes,
  upsells,
  featured,
  type,
} = Astro.props;
---

<div
  class="h-full p-5 sm:p-6 lg:p-8 relative overflow-hidden rounded-3xl bg-zinc-900/50 backdrop-blur-sm border-2 transition-all duration-300 flex flex-col group hover:shadow-2xl cursor-pointer"
  class:list={[
    featured
      ? "border-amber-400 shadow-lg shadow-amber-400/20"
      : "border-amber-400/20 hover:border-amber-400/50",
    type === "custom"
      ? "bg-gradient-to-br from-zinc-900/70 to-amber-950/30"
      : "",
  ]}
>
  <!-- Badges - solo ocupan espacio cuando existen -->
  {featured && (
    <div class="mb-3">
      <div class="inline-block bg-amber-400 text-black text-xs font-bold px-3 py-1 rounded-full shadow-lg">
        ⭐ RECOMENDADO
      </div>
    </div>
  )}
  
  {type === "custom" && !featured && (
    <div class="mb-3">
      <div class="inline-block bg-amber-400/20 text-amber-400 text-xs font-bold px-3 py-1 rounded-full border border-amber-400/30 backdrop-blur-sm">
        ⚡ A MEDIDA
      </div>
    </div>
  )}

  <!-- Icono y precio -->
  <div class="flex items-start justify-between mb-4">
    <div
      class="w-14 h-14 rounded-xl bg-gradient-to-br from-amber-400/40 to-amber-600/40 flex items-center justify-center text-2xl text-black flex-shrink-0"
    >
      <span set:html={icon} />
    </div>

    <div class="text-right">
      <div class="text-2xl font-bold text-white">{price}</div>
      {priceNote && <div class="text-xs text-amber-400/70">{priceNote}</div>}
    </div>
  </div>

  <!-- Contenido -->
  <div class="flex-grow flex flex-col">
    <h2 class="text-xl font-semibold text-white mb-1">{name}</h2>

    <div class="text-sm text-amber-400/80 mb-3 flex items-center gap-1">
      <svg
        class="w-4 h-4"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
        />
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"
        />
      </svg>
      <span>{capacity}</span>
    </div>

    <Paragraph className="text-zinc-400 text-sm mb-4">
      {description}
    </Paragraph>

    <!-- Incluye -->
    <div class="mb-4">
      <h3
        class="text-xs font-semibold text-amber-400 uppercase tracking-wider mb-2"
      >
        Incluye:
      </h3>
      <ul class="space-y-2">
        {includes.slice(0, 4).map((item) => (
          <li class="flex items-start gap-2 text-zinc-300 text-sm">
            <span class="text-amber-400 flex-shrink-0 mt-0.5">✓</span>
            <span>{item}</span>
          </li>
        ))}
        {includes.length > 4 && (
          <li class="text-amber-400/60 text-xs mt-1">
            +{includes.length - 4} elementos más
          </li>
        )}
      </ul>
    </div>

    <!-- Upsells -->
    {upsells && upsells.length > 0 && (
      <div class="mb-4">
        <h3 class="text-xs font-semibold text-amber-400/70 uppercase tracking-wider mb-2">
          Mejora tu experiencia:
        </h3>
        <div class="space-y-1">
          {upsells.map((upsell) => (
            <div class="flex justify-between items-center text-xs">
              <span class="text-zinc-400">{upsell.name}</span>
              <span class="text-amber-400 font-medium">{upsell.price}</span>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Botón -->
    <div class="mt-auto pt-4">
      <div
        class="block w-full py-2.5 text-center rounded-xl text-sm font-medium transition-all duration-300"
        class:list={[
          type === "custom"
            ? "bg-amber-400/10 border border-amber-400/30 text-amber-400 hover:bg-amber-400 hover:text-black"
            : "bg-gradient-to-r from-amber-400 to-amber-500 text-black hover:from-amber-500 hover:to-amber-600",
        ]}
      >
        {type === "custom" ? "Cotizar ahora" : "Seleccionar paquete"}
      </div>
    </div>
  </div>

  <!-- Decoración -->
  <div
    class="absolute bottom-0 right-0 w-32 h-32 bg-amber-400/5 rounded-full blur-2xl"
  />
</div>