---
import "../styles/global.css";
import "../styles/custom.css";
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";
 
export interface Props {
  title: string;
  description?: string;
  keywords?: string;
}
 
const { title, description, keywords } = Astro.props;
---
 
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description || "Producción integral para eventos en CDMX. DJ profesional, audio, iluminación, mobiliario y personal capacitado."} />
    {keywords && <meta name="keywords" content={keywords} />}
    <title>{title} — Constantino Eventos & Producciones</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
 
  <!-- ✅ bg-black en lugar de bg-body -->
  <body class="overflow-x-hidden bg-black text-white">
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>
