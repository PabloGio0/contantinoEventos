---
import Container from "../components/shared/Container.astro";

const WA_URL = "https://wa.me/525581657250?text=Hola,%20quiero%20cotizar%20un%20evento";
const PHONE  = "55 8165 7250";
const EMAIL  = "contacto@constantinoeventos.com"; // cambia por tu email real
const YEAR   = new Date().getFullYear();

const navLinks = [
  { text: "Inicio",    href: "/" },
  { text: "Servicios", href: "/servicios" },
  { text: "Paquetes",  href: "/paquetes" },
  { text: "Galería",   href: "/galeria" },
  { text: "Contacto",  href: "/contacto" },
];

const services = [
  { text: "Audio e Iluminación", href: "/servicios/audio-iluminacion" },
  { text: "DJ Profesional",      href: "/servicios/dj-profesional" },
  { text: "Mobiliario",          href: "/servicios/mobiliario" },
  { text: "Personal",            href: "/servicios/personal-coordinacion" },
];
---

<!-- Schema LocalBusiness para Google Maps / SEO local -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Constantino Eventos & Producciones",
  "description": "Producción integral para eventos en CDMX. Audio profesional, iluminación, DJ, mobiliario y personal capacitado.",
  "url": "https://constantinoeventos.com",
  "telephone": "+525581657250",
  "email": "contacto@constantinoeventos.com",
  "areaServed": [
    { "@type": "City", "name": "Ciudad de México" },
    { "@type": "City", "name": "Nezahualcóyotl" },
    { "@type": "AdministrativeArea", "name": "Área Metropolitana de la Ciudad de México" }
  ],
  "serviceType": [
    "Producción de eventos",
    "Renta de equipo de sonido",
    "Iluminación para eventos",
    "DJ profesional",
    "Renta de mobiliario para eventos"
  ],
  "priceRange": "$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "09:00",
      "closes": "20:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Saturday","Sunday"],
      "opens": "09:00",
      "closes": "18:00"
    }
  ],
  "sameAs": []
}
</script>

<div class="relative mt-16">
  <span class="w-40 h-40 rounded-full bg-amber-400/10 blur-3xl absolute -left-20 bottom-1/3 pointer-events-none"></span>
  <span class="w-80 h-80 rounded-full bg-amber-600/5 blur-3xl absolute -right-20 -top-40 pointer-events-none"></span>

  <footer class="relative bg-gradient-to-b from-zinc-950 to-black border-t border-amber-400/20 pt-16 rounded-t-3xl">
    <div class="absolute inset-0 opacity-20 pointer-events-none rounded-t-3xl overflow-hidden"
      style="background-image: radial-gradient(circle at 1px 1px, rgba(251,191,36,0.05) 1px, transparent 0); background-size: 40px 40px;">
    </div>

    <Container className="pb-8 relative">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

        <!-- Columna 1: Marca + contacto -->
        <div class="lg:col-span-2">
          <a href="/" class="inline-block mb-4">
            <div class="text-2xl font-semibold text-white">
              Constantino <span class="text-amber-400">Eventos</span>
            </div>
            <div class="text-xs text-amber-400/70 tracking-wider mt-0.5">& Producciones</div>
          </a>

          <p class="text-zinc-400 text-sm leading-relaxed max-w-sm mb-6">
            Producción integral para eventos en CDMX. Más de 10 años creando experiencias
            inolvidables con audio profesional, iluminación y logística completa.
          </p>

          <!-- Datos de contacto — NAP consistente para SEO local -->
          <ul class="space-y-3">
            <li>
              <a
                href={WA_URL}
                target="_blank"
                rel="noopener noreferrer"
                class="flex items-center gap-3 text-zinc-300 hover:text-amber-400 transition-colors group"
              >
                <span class="w-8 h-8 rounded-full bg-amber-400/10 border border-amber-400/20 flex items-center justify-center text-amber-400 flex-shrink-0 group-hover:bg-amber-400 group-hover:text-black transition-all duration-300">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                  </svg>
                </span>
                <span class="text-sm">{PHONE}</span>
              </a>
            </li>

            <li>
              <a
                href={`mailto:${EMAIL}`}
                class="flex items-center gap-3 text-zinc-300 hover:text-amber-400 transition-colors group"
              >
                <span class="w-8 h-8 rounded-full bg-amber-400/10 border border-amber-400/20 flex items-center justify-center text-amber-400 flex-shrink-0 group-hover:bg-amber-400 group-hover:text-black transition-all duration-300">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                  </svg>
                </span>
                <span class="text-sm">{EMAIL}</span>
              </a>
            </li>

            <li class="flex items-center gap-3 text-zinc-400">
              <span class="w-8 h-8 rounded-full bg-amber-400/10 border border-amber-400/20 flex items-center justify-center text-amber-400 flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </span>
              <span class="text-sm">CDMX y Área Metropolitana</span>
            </li>
          </ul>
        </div>

        <!-- Columna 2: Navegación -->
        <div>
          <h3 class="text-white font-semibold mb-5 text-sm uppercase tracking-wider">
            Navegación
          </h3>
          <ul class="space-y-3">
            {navLinks.map(link => (
              <li>
                <a
                  href={link.href}
                  class="text-zinc-400 hover:text-amber-400 transition-colors text-sm flex items-center gap-2 group"
                >
                  <span class="w-1 h-1 rounded-full bg-amber-400/40 group-hover:bg-amber-400 transition-colors flex-shrink-0"></span>
                  {link.text}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Columna 3: Servicios -->
        <div>
          <h3 class="text-white font-semibold mb-5 text-sm uppercase tracking-wider">
            Servicios
          </h3>
          <ul class="space-y-3">
            {services.map(s => (
              <li>
                <a
                  href={s.href}
                  class="text-zinc-400 hover:text-amber-400 transition-colors text-sm flex items-center gap-2 group"
                >
                  <span class="w-1 h-1 rounded-full bg-amber-400/40 group-hover:bg-amber-400 transition-colors flex-shrink-0"></span>
                  {s.text}
                </a>
              </li>
            ))}
          </ul>

          <!-- Horario -->
          <div class="mt-8">
            <h3 class="text-white font-semibold mb-3 text-sm uppercase tracking-wider">
              Atención
            </h3>
            <p class="text-zinc-400 text-xs leading-relaxed">
              Lun – Vie: 9:00 – 20:00<br/>
              Sáb – Dom: 9:00 – 18:00
            </p>
          </div>
        </div>

      </div>
    </Container>

    <!-- Barra inferior -->
    <div class="border-t border-amber-400/10 mt-12">
      <Container>
        <div class="flex flex-col sm:flex-row justify-between items-center gap-4 py-6 text-xs text-zinc-500">
          <p>© {YEAR} Constantino Eventos & Producciones. Todos los derechos reservados.</p>
          <p class="text-zinc-600">
            Servicio disponible en CDMX y Área Metropolitana
          </p>
        </div>
      </Container>
    </div>
  </footer>
</div>