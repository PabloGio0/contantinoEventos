---
import Container from "../components/shared/Container.astro";
import Navitem from "../components/shared/Navitem.astro";
import BtnLink from "../components/shared/BtnLink.astro";
import monograma from "../assets/logos/monograma.svg";

const navItems = [
  {
    href: "#",
    text: "Inicio",
  },
  {
    href: "#solutions",
    text: "Servicios",
  },
  {
    href: "#services",
    text: "Galería",
  },
  {
    href: "#features",
    text: "Nosotros",
  },
  {
    href: "#faq",
    text: "Contacto",
  },
];
---

<header
  id="navbar"
  class="fixed inset-x-0 top-0 z-50 py-6 transition-all duration-500 bg-transparent"
>
  <Container>
    <nav class="w-full flex items-center justify-between relative">
      <!-- LOGO -->
      <a href="/" class="flex items-center gap-3">
        <img
          src={monograma.src}
          alt="Monograma Constantino"
          class="w-9 h-9 object-contain"
        />

        <div class="text-lg font-semibold text-white tracking-wide">
          Constantino Eventos & Producciones
        </div>
      </a>

      <!-- BOTÓN HAMBURGUESA -->
      <button
        id="menu-toggle"
        class="lg:hidden text-white text-2xl"
        aria-label="Abrir menú"
      >
        ☰
      </button>

      <!-- LINKS (CENTRADOS EN DESKTOP) -->
      <ul
        id="mobile-menu"
        class="hidden lg:flex flex-col lg:flex-row gap-6 text-lg
          absolute lg:static top-full left-0 w-full lg:w-auto
          bg-slate-950/95 lg:bg-transparent
          backdrop-blur-md lg:backdrop-blur-none
          p-6 lg:p-0
          items-center
          lg:mx-auto"
      >
        {navItems.map((item) => <Navitem {...item} />)}

        <!-- CTA EN MOBILE -->
      </ul>

      <!-- CTA EN DESKTOP -->
      <div class="hidden lg:block">
        <a
          href="#cta"
          class="px-6 py-3 rounded-full font-medium border border-white text-white hover:bg-amber-400 hover:text-black hover:border-black transition-all duration-500"
        >
          Cotizar Mi Evento
        </a>
      </div>
    </nav>
  </Container>

  <script>
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");

    toggle?.addEventListener("click", () => {
      menu?.classList.toggle("hidden");
    });
  </script>
</header>
