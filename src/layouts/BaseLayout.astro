---
import Navbar from "./Navbar.astro";
import Footer from "./Footer.astro";

export interface Props {
  title?: string;
}

const { title = "Constantino Eventos & Producciones" } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta
      name="description"
      content="Producción integral de eventos en CDMX: DJ profesional, audio e iluminación, mobiliario, meseros y todo lo necesario para tu evento."
    />
  </head>

  <body class="bg-slate-950 text-white antialiased">

    <Navbar />

    <main>
      <slot />
    </main>

    <Footer />

  </body>
</html>